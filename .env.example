# ================================
# DÉVELOPPEMENT LOCAL
# ================================

# Configuration XAMPP MySQL (local)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=congochallenge
DB_USER=root
DB_PASSWORD=

# Configuration Serveur
PORT=3001
NODE_ENV=development
VERCEL=0

# Configuration JWT
JWT_SECRET=ccl-beats-for-peace-dev-secret-2026
JWT_REFRESH_SECRET=ccl-beats-for-peace-refresh-secret-2026
JWT_EXPIRES_IN=7d

# Configuration Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=votre_email@gmail.com
EMAIL_PASS=votre_mot_de_passe_app
EMAIL_FROM=noreply@cclbeats.com

# Configuration Upload
UPLOAD_PATH=uploads
MAX_FILE_SIZE=10485760

# Configuration URLs
FRONTEND_URL=http://localhost:8080
BACKEND_URL=http://localhost:3001

# ================================
# PRODUCTION (Vercel)
# ================================
# Remplacez les valeurs ci-dessous pour le déploiement Vercel

# VERCEL=1
# NODE_ENV=production

# Base de données (utiliser cloud: PlanetScale, Railway, etc.)
# DB_HOST=your-cloud-db.mysql.com
# DB_PORT=3306
# DB_NAME=your_production_db
# DB_USER=production_user
# DB_PASSWORD=your_secure_password

# JWT (Générez une clé sécurisée aléatoire)
# JWT_SECRET=generate-a-random-secure-key-here-min-32-chars

# Frontend  
# FRONTEND_URL=https://app.cclbeats.com

# Email service
# EMAIL_USER=backend@cclbeats.com
# EMAIL_PASS=your-app-specific-password

# TikTok OAuth (si applicable)
# TIKTOK_CLIENT_ID=your-client-id
# TIKTOK_CLIENT_SECRET=your-client-secret
# TIKTOK_REDIRECT_URI=https://api.cclbeats.com/api/tiktok/oauth/callback
